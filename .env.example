# geo-orchestrator — Variáveis de ambiente
# Copie para .env e preencha com suas chaves.

# Anthropic (Claude Opus) — Decomposição, arquitetura, código, revisão
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-5.5) — Sprint 12: PREMIUM canonical de writing/copywriting/seo
# Lançado 23-04-2026, 1M ctx + reasoning nativo + pt-BR otimizado.
# Opcionalmente override via OPENAI_MODEL (default gpt-5.5).
OPENAI_API_KEY=sk-...

# Perplexity (sonar-deep-research) — Sprint 12: PRIORIDADE ABSOLUTA em research/fact_check
# Cap restaurado 0.35 → 0.50. Único provider com live web + citações academicamente verificáveis.
PERPLEXITY_API_KEY=pplx-...

# Google (Gemini 2.5 Pro/Flash) — Pro em code/analysis/decomposition, Flash em bulk medium
# Billing ativo. 30 RPM (Pro) / 60 RPM (Flash). Override via GEMINI_MODEL / GEMINI_FLASH_MODEL.
GOOGLE_AI_API_KEY=AIza...

# Groq Inc (com Q) — Llama 4 Scout 17B 16E + openai/gpt-oss-120b (groq_heavy)
GROQ_API_KEY=gsk_...

# xAI Grok (com K) — Sprint 11: 6º provider canônico. Live X/Twitter via search_parameters.
# API OpenAI-compatible em https://api.x.ai/v1. Pricing flat $1.25/$2.50 por 1M tokens.
XAI_API_KEY=xai-...
