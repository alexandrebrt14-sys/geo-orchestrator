# geo-orchestrator — Variáveis de ambiente
# Copie para .env e preencha com suas chaves.

# Anthropic (Claude Opus) — Decomposição, arquitetura, código, revisão
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o) — Redação de conteúdo longo
OPENAI_API_KEY=sk-...

# Perplexity (sonar-pro) — Pesquisa com fontes em tempo real
PERPLEXITY_API_KEY=pplx-...

# Google (Gemini Flash) — Análise de dados rápida
GOOGLE_API_KEY=AIza...
